{
  "project_id": "REPLACE_WITH_PROJECT_ID",
  "communication_mode": "local-poller",
  "tmux_server": "",
  "account": "REPLACE_WITH_ACCOUNT_NAME",
  "chat_id": "REPLACE_WITH_CHAT_ID",
  "channel": "main",
  "enabled_roles": [
    "CPO"
  ],
  "hook_debounce_seconds": 30,
  "voice_transcription": {
    "enabled": false,
    "base_url": "http://127.0.0.1:8768",
    "session_token": "speak2-local-dev-token",
    "language": "en",
    "ffmpeg_path": "/opt/homebrew/bin/ffmpeg"
  },
  "voice_synthesis": {
    "enabled": false,
    "base_url": "http://127.0.0.1:8770",
    "session_token": "kokoro-local-dev-token",
    "default_voice": "af_heart",
    "default_speed": 1.25,
    "language": "en-us",
    "ffmpeg_path": "/opt/homebrew/bin/ffmpeg"
  },
  "roles": {
    "CPO": {
      "agent_name": "CPO",
      "inbound_mode": "inject",
      "tmux_session": "cpo"
    }
  }
}
