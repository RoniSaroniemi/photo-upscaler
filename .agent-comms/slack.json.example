{
  "project_id": "REPLACE_WITH_PROJECT_ID",
  "communication_mode": "local-poller",
  "tmux_server": "",
  "account": "REPLACE_WITH_ACCOUNT_NAME",
  "default_channel": "REPLACE_WITH_CHANNEL_ID",
  "channel": "main",
  "enabled_roles": ["CPO"],
  "hook_debounce_seconds": 30,
  "rate_limit": {
    "min_interval_ms": 1100,
    "retry_after_cap_seconds": 30
  },
  "roles": {
    "CPO": {
      "agent_name": "CPO",
      "inbound_mode": "inject",
      "tmux_session": "cpo"
    }
  }
}
