# =============================================================================
# Honest Image Tools — Required Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.

# --- Database (Neon Serverless Postgres) ---
# Connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- Stripe ---
# Secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — run `stripe listen --forward-to localhost:3001/api/balance/webhook`
# or get from Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Google Cloud Storage ---
# Bucket for storing upscaled results
GCS_BUCKET_NAME=honest-image-tools-results

# --- Inference Service (optional in dev) ---
# Cloud Run URL for the upscaling service. Omit for mock mode in development.
# INFERENCE_SERVICE_URL=https://inference-service-XXXXX-uc.a.run.app

# --- Auth: Email (Magic Link via Gmail SMTP) ---
# Gmail address used as the sender for magic link emails
EMAIL_FROM=you@gmail.com

# Gmail App Password (generate at https://myaccount.google.com/apppasswords)
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Auth: JWT ---
# Random secret for signing session tokens (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-random-secret

# --- Public ---
# Base URL for magic link emails. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Dev Helpers (optional) ---
# Set to a UUID to bypass auth in development
# MOCK_USER_ID=00000000-0000-0000-0000-000000000001
