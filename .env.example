# Backend
PORT=8080
TEMP_DIR=/tmp/upscaler
MAX_FILE_SIZE_MB=10
MODEL_NAME=RealESRGAN_x4plus
SCALE_FACTOR=4

# Pricing (cost per image in USD)
COMPUTE_COST_PER_IMAGE=0.02
PLATFORM_FEE_PER_IMAGE=0.03

# Auth & Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=http://localhost:3000

# GCP (for production)
GCP_PROJECT_ID=photo-upscaler-24h
GCP_REGION=us-central1
