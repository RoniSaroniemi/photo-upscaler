{
  "id": "customer-monitoring",
  "name": "Customer Activity Monitoring",
  "description": "Daily check of customer org activity levels, classification, and Slack reporting",
  "version": "1.0",
  "enabled": false,

  "schedule": {
    "cron": "0 9 * * 1-5",
    "timezone": "Europe/Helsinki",
    "description": "Weekdays at 9am Helsinki time"
  },

  "steps": [
    {
      "id": "collect",
      "type": "script",
      "command": "python3 steps/collect_data.py",
      "timeout_seconds": 300,
      "requires": [],
      "produces": ["raw-data.json"]
    },
    {
      "id": "classify",
      "type": "script",
      "command": "python3 steps/classify.py",
      "timeout_seconds": 60,
      "requires": ["raw-data.json"],
      "produces": ["analysis.json"]
    },
    {
      "id": "report",
      "type": "script",
      "command": "python3 steps/send_report.py",
      "timeout_seconds": 60,
      "requires": ["analysis.json"],
      "produces": []
    }
  ],

  "notifications": {
    "on_success": {
      "slack": false,
      "telegram": false,
      "message_template": "Customer monitoring completed: {summary}"
    },
    "on_failure": {
      "slack": true,
      "telegram": true,
      "escalate_to_cpo": true,
      "message_template": "Customer monitoring FAILED at step '{failed_step}': {error}"
    }
  },

  "artifacts": {
    "retention_days": 90,
    "retention_max_runs": 200
  },

  "metadata": {
    "created": "2026-03-25T00:00:00Z",
    "created_by": "orchestration-scaffolding",
    "last_modified": "2026-03-25T00:00:00Z",
    "tags": ["customer-success", "monitoring", "daily"]
  }
}
